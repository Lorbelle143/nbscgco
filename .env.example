VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key
VITE_ADMIN_MASTER_KEY=your_admin_master_key

# Cloudinary — Primary account
VITE_CLOUDINARY_CLOUD_NAME=your_cloud_name
VITE_CLOUDINARY_UPLOAD_PRESET=your_upload_preset

# Cloudinary — Backup account (optional but recommended)
# Can be a second Cloudinary account OR same account with a different upload preset
VITE_CLOUDINARY_BACKUP_CLOUD_NAME=your_backup_cloud_name
VITE_CLOUDINARY_BACKUP_UPLOAD_PRESET=your_backup_upload_preset
